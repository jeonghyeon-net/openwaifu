#!/usr/bin/env bash
set -euo pipefail

if ! git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' | grep -q .; then
  exit 0
fi

git diff --cached --name-only -z --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' | xargs -0 bunx biome check --fix --diagnostic-level=warn

git diff --cached --name-only -z --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' | xargs -0 git add

git diff --cached --name-only -z --diff-filter=ACMR -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' | xargs -0 bunx biome check --diagnostic-level=warn

bun --filter '*' check
